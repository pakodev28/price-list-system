# Copy to .env and adjust. .env is git-ignored.

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database (must match the postgres service below)
DATABASE_URL=postgres://postgres:postgres@db:5432/price_list
POSTGRES_DB=price_list
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Matching
MATCHER_STRATEGY=hybrid
MATCH_THRESHOLD=0.75
MATCH_SHORTLIST_SIZE=5

# LLM (TimeWeb cloud agent — OpenAI-compatible). Leave LLM_ENABLED=False to run fully offline.
LLM_ENABLED=False
LLM_BASE_URL=https://agent.timeweb.cloud/api/v1/cloud-ai/agents/<agent-id>/v1
LLM_API_KEY=
LLM_MODEL=dashscope/qwen3.5-plus
LLM_TIMEOUT=30
LLM_MAX_TOKENS=4096

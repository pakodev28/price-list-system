# Copy to .env and adjust. .env is git-ignored.

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database (must match the postgres service below)
DATABASE_URL=postgres://postgres:postgres@db:5432/price_list
POSTGRES_DB=price_list
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Matching (see config/settings/base.py for the full set of tunable knobs)
MATCHER_STRATEGY=hybrid
MATCH_THRESHOLD=0.75
MATCH_SHORTLIST_SIZE=8

# --- AI matching: LLM rerank (OPTIONAL) ---
# The app works fully OFFLINE with LLM_ENABLED=False — article + lexical + local
# semantic (model2vec) matching need no API key. The LLM only reranks the
# ambiguous middle. To enable it you have two options:
#   1) Use the author's key  — set LLM_ENABLED=True and paste the BASE_URL / API_KEY
#      / MODEL values the author provides.
#   2) Bring your own        — point these at ANY OpenAI-compatible endpoint
#      (OpenAI, TimeWeb, local vLLM/Ollama, ...) with your own key and model.
LLM_ENABLED=False
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=30
LLM_MAX_TOKENS=4096
